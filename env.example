# ============================================================
#   LOAN ASSISTANT — ENVIRONMENT VARIABLES
#   Copy this file to .env and fill in your values
# ============================================================

# ------ OpenAI ------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ------ Database (PostgreSQL) ------
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/loan_db

# ------ App Settings ------
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-string

# ------ Streamlit Frontend ------
API_BASE_URL=http://localhost:8000
